
@inproceedings{roumpas_distinguishing_2025,
	address = {New York, NY, USA},
	series = {{CHIGreece} '25},
	title = {Distinguishing {Voluntary} and {Involuntary} {Blinks} {Through} {Eye} {Openness} {Metrics}},
	isbn = {979-8-4007-1561-7},
	url = {https://dl.acm.org/doi/10.1145/3749012.3749079},
	doi = {10.1145/3749012.3749079},
	abstract = {Understanding and characterizing blinks can contribute to developing applications in human-computer interaction, fatigue monitoring, and medical diagnosis. This study involved the collection and analysis of eye-tracking data from 44 subjects to monitor voluntary and involuntary blinks. Using eye-openness metrics, our work builds on previous research that uses the same metric to monitor blinks. Blink duration thresholds were obtained from past studies involving eye images and were categorized as voluntary, involuntary, or invalid. In addition, a neural network model was developed and trained to classify blinks as voluntary or involuntary. The model achieved 92\% accuracy on the test set, demonstrating the effectiveness of using eye-openness values for this classification task. This open-access dataset and model can provide a solid foundation for further research and applications in automated blink detection and analysis, and the potential creation of interactive systems that take voluntary blinks as input.},
	urldate = {2025-10-02},
	booktitle = {Proceedings of the 3rd {International} {Conference} of the {ACM} {Greek} {SIGCHI} {Chapter}},
	publisher = {Association for Computing Machinery},
	author = {Roumpas, Konstantinos and Minas, Dimosthenis and Calvo-Cordoba, Alberto and Xenos, Michalis},
	month = sep,
	year = {2025},
	pages = {222--226},
	file = {Full Text PDF:C\:\\Users\\NtinosRoumpas\\Zotero\\storage\\3DBKESQB\\Roumpas et al. - 2025 - Distinguishing Voluntary and Involuntary Blinks Through Eye Openness Metrics.pdf:application/pdf},
}

@inproceedings{roumpas_bridging_2025,
	title = {Bridging the {Gap} {Between} {Educators} and {Game}-{Based} {Learning}: {A} {Study} of an {AI}-{Assisted} {Course} {Creation} {Tool} for {Minecraft} {Education}},
	copyright = {All rights reserved},
	shorttitle = {Bridging the {Gap} {Between} {Educators} and {Game}-{Based} {Learning}},
	url = {https://ieeexplore.ieee.org/document/11064146},
	doi = {10.1109/AICCONF64766.2025.11064146},
	abstract = {This paper explores the involvement of artificial intelligence in the context of educational technology. Specifically, it presents findings from a study evaluating CourseCrafter, an AI-enhanced prototype designed to assist to the creation of Minecraft Education courses by educators, regardless of their coding expertise or familiarity with Minecraft’s controls. The study aimed to gather insights on user experiences, interface usability, and the effectiveness of AI integration within the tool. Ten educators, all of whom had some experience with Minecraft Education prior to the experiment, from different geographical areas, teaching grade and subject areas tested the prototype, completed a System Usability Scale (SUS) questionnaire, and attended a semi-structured interview. To ensure a controlled environment throughout the prototype testing, user personas were randomly handed out to participants, they were instructed to follow a detailed scenario, and alternative options would be explained with the Wizard of Oz method. The participants unanimously found the idea useful, agreed on the functionality of certain features, but shared varied concerns about the use of AI in education and the complexity of the platform. Additionally, feedback highlighted the importance of intuitive design, adequate instructional resources, and the potential impact of the tool on teaching and student engagement. These findings emphasize both the need for refinements to enhance user experience and maximize educational effectiveness but also the demand of such a tool in the industry.},
	urldate = {2025-07-11},
	booktitle = {2025 3rd {Cognitive} {Models} and {Artificial} {Intelligence} {Conference} ({AICCONF})},
	author = {Roumpas, Konstantinos and Xenos, Michalis},
	month = jun,
	year = {2025},
	keywords = {artificial intelligence, Educational technology, Encoding, game-based learning, Human computer interaction, human-computer interaction, Industries, Interviews, Learning (artificial intelligence), Minecraft, Prototypes, Testing, Usability, User experience},
	pages = {1--7},
	file = {Full Text PDF:C\:\\Users\\NtinosRoumpas\\Zotero\\storage\\NV73EUN3\\Roumpas and Xenos - 2025 - Bridging the Gap Between Educators and Game-Based Learning A Study of an AI-Assisted Course Creatio.pdf:application/pdf},
}

@article{roumpas_comparative_2025,
	title = {A comparative study of physics-informed and conventional neural networks for predicting on-screen gaze points from eye-tracking data},
	volume = {281},
	copyright = {All rights reserved},
	issn = {0957-4174},
	url = {https://www.sciencedirect.com/science/article/pii/S0957417425012771},
	doi = {10.1016/j.eswa.2025.127655},
	abstract = {Physics-Informed Neural Networks (PINNs) take advantage of physical constraints to improve the predictive performance of neural networks. They have demonstrated remarkable success in physics, chemistry, biology, and medicine, sparking interest in their potential applications in other fields, such as Human-Computer Interaction (HCI). Despite their versatility, PINNs are underutilized in certain disciplines due to the challenge of defining Partial Differential Equations (PDEs) that adequately constrain specific problems. This study investigates the application of PINNs to predict fixations captured by an eye-tracking device, employing equations that model head and eye movements. The data for this study were collected during an experiment involving an adaptive user interface for pilots, encompassing a variety of fixation points and rapid glances. The results establish PINNs as a superior method, achieving a mean absolute error (MAE) of 0.61 for horizontal predictions (X) and 0.35 for vertical predictions (Y), significantly outperforming the conventional neural network (NN). Additionally, the PINN demonstrated stronger predictive accuracy for vertical gaze dynamics, as evidenced by an RY2 of 0.91 compared to 0.85 for the NN. These findings underscore the robustness of the PINN approach in modeling gaze points with enhanced precision and reliability. While conventional neural networks perform adequately, the added benefit of physical constraints in PINNs encourages further exploration of their application in non-natural science domains. These promising results point toward the potential of PINNs in creating more adaptive and context-aware systems for various HCI applications.},
	urldate = {2025-04-25},
	journal = {Expert Systems with Applications},
	author = {Roumpas, Konstantinos and Michanetzi, Eleftheria-Lito and Minas, Dimosthenis and Fotopoulos, Angelos and Xenos, Michalis},
	month = jul,
	year = {2025},
	keywords = {Machine learning, Eye-tracking, Gaze point prediction, Human–computer interaction, Physics-informed neural networks},
	pages = {127655},
	file = {ScienceDirect Snapshot:C\:\\Users\\NtinosRoumpas\\Zotero\\storage\\Q9PN4RE3\\S0957417425012771.html:text/html},
}

@inproceedings{roumpas_design_2024,
	title = {Design of an {AI}-{Assisted} {Platform} that will {Facilitate} {Educators} in {Creating} {Minecraft} {Education} {Courses}},
	copyright = {All rights reserved},
	url = {https://ieeexplore.ieee.org/document/10904374},
	doi = {10.1109/WAIE63876.2024.00043},
	abstract = {The potential of Education Technology has reached a point where teachers cannot keep up with the latest trends, nor they can spend the time to get accustomed to innovative technologies that might become obsolete in a few years. With the rise in the popularity of Minecraft Education, an educational platform based on the engine of the world-famous video-game: Minecraft, as well as the benefits of gamification in classrooms for all student ages, it seems that an application that would help teachers create educational video games that are run on Minecraft Education, without any code and with artificial intelligence assistance, could be just the thing that they need to update their teaching techniques. We propose the creation of a platform like that, and we present its potential design, after being consulted by the available research that has been done to this day regarding instructional design, user interface and applications that utilize large language models.},
	urldate = {2025-03-14},
	booktitle = {2024 6th {International} {Workshop} on {Artificial} {Intelligence} and {Education} ({WAIE})},
	author = {Roumpas, Konstantinos and Xenos, Michalis},
	month = sep,
	year = {2024},
	keywords = {human-computer interaction, AI, e-learning, Codes, Conferences, Educational courses, Engines, gamification, Large language models, Market research, minecraft, User interfaces, Video games},
	pages = {197--201},
	file = {Full Text PDF:C\:\\Users\\NtinosRoumpas\\Zotero\\storage\\KNBQVGXE\\Roumpas and Xenos - 2024 - Design of an AI-Assisted Platform that will Facilitate Educators in Creating Minecraft Education Cou.pdf:application/pdf;IEEE Xplore Abstract Record:C\:\\Users\\NtinosRoumpas\\Zotero\\storage\\DHAFIBZG\\10904374.html:text/html},
}

@article{minas_adaptive_2025,
	title = {Adaptive {Real}-{Time} {Translation} {Assistance} {Through} {Eye}-{Tracking}},
	volume = {6},
	copyright = {http://creativecommons.org/licenses/by/3.0/},
	issn = {2673-2688},
	url = {https://www.mdpi.com/2673-2688/6/1/5},
	doi = {10.3390/ai6010005},
	abstract = {This study introduces the Eye-tracking Translation Software (ETS), a system that leverages eye-tracking data and real-time translation to enhance reading flow for non-native language users in complex, technical texts. By measuring the fixation duration, we can detect moments of cognitive load, ETS selectively provides translations, maintaining reading flow and engagement without undermining language learning. The key technological components include a desktop eye-tracker integrated with a custom Python-based application. Through a user-centered design, ETS dynamically adapts to individual reading needs, reducing cognitive strain by offering word-level translations when needed. A study involving 53 participants assessed ETS’s impact on reading speed, fixation duration, and user experience, with findings indicating improved comprehension and reading efficiency. Results demonstrated that gaze-based adaptations significantly improved their reading experience and reduced cognitive load. Participants positively rated ETS’s usability and were noted through preferences for customization, such as pop-up placement and sentence-level translations. Future work will integrate AI-driven adaptations, allowing the system to adjust based on user proficiency and reading behavior. The study contributes to the growing evidence of eye-tracking’s potential in educational and professional applications, offering a flexible, personalized approach to reading assistance that balances language exposure with real-time support.},
	language = {en},
	number = {1},
	urldate = {2025-01-07},
	journal = {AI},
	publisher = {Multidisciplinary Digital Publishing Institute},
	author = {Minas, Dimosthenis and Theodosiou, Eleanna and Roumpas, Konstantinos and Xenos, Michalis},
	month = jan,
	year = {2025},
	note = {Number: 1},
	keywords = {human-computer interaction, adaptive learning tools, eye-tracking technology, non-native language assistance, reading aid, reading comprehension, real-time translation},
	pages = {5},
	file = {Full Text PDF:C\:\\Users\\NtinosRoumpas\\Zotero\\storage\\7YU5RVG6\\Minas et al. - 2025 - Adaptive Real-Time Translation Assistance Through Eye-Tracking.pdf:application/pdf},
}
